{
  "name": "blendtype",
  "type": "module",
  "version": "0.0.3-alpha.5",
  "packageManager": "pnpm@10.23.0",
  "description": "A TypeScript wrapper for the Galaxy REST API built on Effect-TS. Provides type-safe, composable operations for workflows, histories, datasets, and TUS resumable uploads.",
  "author": "Rémi Planel <rplanel@pasteur.fr>",
  "license": "MIT",
  "homepage": "https://github.com/rplanel/gaas#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rplanel/gaas.git"
  },
  "bugs": "https://github.com/rplanel/gaas/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "vitest dev",
    "lint": "eslint .",
    "lint:fix": "automd && eslint . --fix",
    "prepack": "pnpm build",
    "play": "jiti playground",
    "release:publish": "pnpm publish --access public",
    "test": "pnpm lint && pnpm typecheck && vitest run --coverage",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "cleandep": "rm -rf node_modules dist"
  },
  "dependencies": {
    "dotenv": "catalog:",
    "effect": "catalog:",
    "h3": "catalog:",
    "ofetch": "catalog:",
    "tus-js-client": "catalog:",
    "ufo": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/tus-js-client": "catalog:",
    "@vue/compiler-core": "catalog:",
    "automd": "catalog:",
    "changelogen": "catalog:",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "eslint-config-unjs": "catalog:",
    "jiti": "catalog:",
    "simple-git-hooks": "catalog:",
    "typescript": "catalog:",
    "unbuild": "catalog:",
    "vitest": "catalog:testing"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
