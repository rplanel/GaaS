{
  "name": "gaas",
  "version": "0.0.3-alpha.5",
  "private": true,
  "packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489",
  "description": "",
  "author": "",
  "license": "ISC",
  "keywords": [],
  "scripts": {
    "test": "pnpm --filter './packages/**' test",
    "dev": "pnpm run supabase:start && pnpm --filter ./playground dev",
    "lint": "pnpm --filter './packages/**' lint",
    "cleandep": "rm -rf node_modules pnpm-lock.yaml && pnpm --filter '**' run cleandep && pnpm install",
    "build": "pnpm --filter './packages/**' prepack",
    "dev:prepare": "pnpm --filter './packages/**' run dev:prepare",
    "typecheck": "pnpm --filter './packages/**' run typecheck",
    "docs:dev": "pnpm --filter ./docs dev",
    "docs:build": "pnpm --filter ./docs build",
    "docs:generate": "pnpm --filter ./docs generate",
    "release": "pnpm run lint && pnpm run typecheck && pnpm run test && changelogen --output CHANGELOG.md && jiti scripts/release.ts && pnpm -r run release:publish && git push --follow-tags",
    "supabase:status": "pnpm supabase --workdir packages/nuxt-galaxy status",
    "supabase:start": "pnpm supabase --workdir packages/nuxt-galaxy start",
    "supabase:stop": "pnpm supabase --workdir packages/nuxt-galaxy stop"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@unocss/eslint-plugin": "catalog:",
    "bumpp": "catalog:",
    "changelogen": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "fs-extra": "catalog:",
    "jiti": "catalog:",
    "lint-staged": "catalog:",
    "msw": "catalog:testing",
    "simple-git-hooks": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
