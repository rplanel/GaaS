{
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll": "never",
    "source.fixAll.eslint": "explicit"
  },
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "prettier.enable": false,
  "tailwindCSS.classAttributes": ["class", "ui"],
  "tailwindCSS.classFunctions": ["defineAppConfig"],
  "tailwindCSS.experimental.classRegex": [
    ["[:\\[,]\\s*['\"`]([^'\"`]*)['\"`]"]
  ],
  "tailwindCSS.experimental.configFile": {
    "playgrounds/nuxt/app/assets/css/main.css": ["playgrounds/nuxt/**", "src/**"],
    "playgrounds/vue/src/assets/css/main.css": "playgrounds/vue/**",
    "playgrounds/repl/src/main.css": "playgrounds/repl/**",
    "docs/app/assets/css/main.css": "docs/**"
  }
}
