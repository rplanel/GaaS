{
  "name": "@zod/integration",
  "type": "module",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.68",
    "@types/node": "^22.19.20",
    "ai": "^6.0.197",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "test:all": "pnpm test:source && pnpm test:built",
    "test:source": "tsc --project fixtures/drizzle-zod/tsconfig.json 2>&1 | (! grep -q 'excessively deep') && tsc --project fixtures/ai-sdk/tsconfig.json",
    "test:built": "tsc --project fixtures/internal-types/tsconfig.bundler.json && tsc --project fixtures/internal-types/tsconfig.nodenext.json && tsc --project fixtures/internal-types/tsconfig.node16-cjs.json"
  },
  "dependencies": {
    "zod": "workspace:*"
  }
}
